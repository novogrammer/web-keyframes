{
  "name": "web-keyframes",
  "version": "0.3.0",
  "description": "Lightweight keyframe editor core and CSS generator for web animations.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.js"
    },
    "./editor.css": "./dist/editor.css"
  },
  "typesVersions": {
    "*": {
      "editor": [
        "./dist/editor.d.ts"
      ],
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "bin": {
    "web-keyframes": "./bin/web-keyframes.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts src/editor.ts --format esm --dts --clean && node scripts/copy-editor-css.mjs",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --import tsx --test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "jsdom": "^26.0.0",
    "sass": "^1.101.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
